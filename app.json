{
  "expo": {
    "name": "TrainAsyst",
    "slug": "TrainAsyst",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ciccio.TrainAsyst"
    },
    "android": {
      "package": "com.ciccio.TrainAsyst",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "description": "App per la gestione atleti e allenamenti",
      "shortName": "TrainAsyst"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}